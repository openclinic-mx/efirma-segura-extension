    "laravel-echo": "^2.3.4",
    "pinia": "^3.0.4",
    "pusher-js": "^8.5.0",
    "vue": "^3.5.34",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nuxt/ui": "^4.7.1",
    "@tailwindcss/typography": "^0.5.19",
